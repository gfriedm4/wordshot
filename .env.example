# The hidden engine. Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-key-here

# Optional overrides
# GEMINI_MODEL=gemini-2.5-flash
# PORT=3000

# Enables the admin endpoint (POST /api/admin/remove) to pull a leaderboard row
# or clear a day. Leave unset to disable it. Set to a long random string.
# ADMIN_TOKEN=

# Per-IP rate limits (defaults shown). Generate is the paid path, so it's
# capped tightest; writes are name-set/score-submit.
# RL_GEN_PER_MIN=20
# RL_GEN_PER_DAY=400
# RL_WRITE_PER_MIN=40

# Global circuit breaker: max paid Gemini renders per day across ALL users
# (cache hits don't count). Backstops the per-IP caps against a swarm of IPs
# running up the bill. Default 2000. Set to 0 to disable. Pair this with a
# billing alert in Google Cloud so you hear about a spike even if the cap holds.
# GEN_GLOBAL_DAILY_MAX=2000
