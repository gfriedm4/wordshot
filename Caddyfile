# Caddy fetches and renews a Let's Encrypt cert for these names automatically.
# www redirects to the apex.
wordshot.art {
	encode zstd gzip

	# Security headers. The CSP is tight: scripts/fonts/connections are same-origin
	# only, with the one exception of stats.wordshot.art so the Umami tracker can
	# load and send beacons. Styles allow 'unsafe-inline' for the inline style=""
	# attributes in the markup; img allows data: for the SVG-to-canvas render in app.js.
	header {
		Content-Security-Policy "default-src 'self'; script-src 'self' https://stats.wordshot.art; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self' https://stats.wordshot.art; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; object-src 'none'"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		X-Frame-Options "DENY"
		-Server
	}

	# Long cache for the immutable self-hosted fonts; everything else stays default.
	@fonts path /fonts/*
	header @fonts Cache-Control "public, max-age=31536000, immutable"

	reverse_proxy wordshot:3000
}

# Self-hosted Umami analytics on its own subdomain so it serves at root (the
# prebuilt image can't run under a subpath: BASE_PATH is build-time only). Caddy
# auto-fetches a cert once stats.wordshot.art's A record points at this box.
stats.wordshot.art {
	encode zstd gzip
	reverse_proxy umami:3000
}

www.wordshot.art {
	redir https://wordshot.art{uri}
}
